# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Supabase self-hosted URL (same for all products on shared instance)
VITE_SUPABASE_URL=https://your-supabase-url

# Supabase anon key (get from Supabase dashboard → Settings → API)
VITE_SUPABASE_ANON_KEY=your-anon-key

# Public URL of this product's web app (used in TG Mini App links, etc.)
VITE_APP_URL=https://your-product-domain

# Product identifier (beauty, clinic, workshop, edu, etc.)
VITE_PRODUCT=beauty

# Telegram bot usernames (without @)
VITE_MASTER_BOT=ezzepro_bot
VITE_CLIENT_BOT=ezzeprogo_bot

# ── TG Master Bot ─────────────────────────────────────────────────────────────
# Bot token from @BotFather (register a new bot for each product)
TG_BOT_TOKEN=your-master-bot-token

# ── TG Client Bot ─────────────────────────────────────────────────────────────
# Bot token from @BotFather (register a new bot for each product)
TG_CLIENT_BOT_TOKEN=your-client-bot-token

# ── TG Bots shared ───────────────────────────────────────────────────────────
# Same Supabase URL (without /rest/v1 — raw base URL)
SUPABASE_URL=https://your-supabase-url

# Supabase service role key (keep secret — server-side only)
SUPABASE_SERVICE_KEY=your-service-role-key

# Web app URL for links in bot messages
APP_URL=https://your-product-domain

# Product identifier — used in logs to distinguish bots on shared VPS
# Examples: beauty, workshop, clinic, farm, edu, event, food, hotel, transport, build
PRODUCT=beauty

# Optional: Anthropic API key for AI assistant features
ANTHROPIC_API_KEY=
